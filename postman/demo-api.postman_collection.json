            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Postman\",\n  \"email\": \"usuario.{{$timestamp}}@teste.com\",\n  \"senha\": \"senha123\",\n  \"telefone\": \"11999999999\",\n  \"perfil\": \"GERENTE_PROJETO\"\n}"
